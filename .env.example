# Copy to .env.local if you want to test production-style socket URL locally.
#
# --- Vercel (Next.js) + Railway (Socket.IO) ---
# 1. Deploy this repo on Railway: start command `node server/index.js`, root = repo root.
#    Railway sets PORT; your service gets a URL like https://xxx.up.railway.app
# 2. In Vercel → Environment Variables, set (no trailing slash):
# NEXT_PUBLIC_SOCKET_URL=https://your-service.up.railway.app
#
NEXT_PUBLIC_SOCKET_URL=

# --- Railway socket service only (optional; Railway injects PORT) ---
# PORT=3001
